# akgentic-infra — Environment Variables
# Copy to .env and fill in values

# --- Server Settings (all tiers) ---
# AKGENTIC_HOST=0.0.0.0
# AKGENTIC_PORT=8000
# AKGENTIC_CORS_ORIGINS=["*"]
# AKGENTIC_FRONTEND_ADAPTER=

# --- Community Settings ---
# AKGENTIC_WORKSPACES_ROOT=workspaces
# AKGENTIC_CATALOG_PATH=

# --- LLM Provider Keys (required for team execution) ---
# At least one provider key is needed for agents to function.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Observability (optional) ---
# LOGFIRE_TOKEN=
