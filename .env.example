# akgentic-infra — Environment Variables
# Copy to .env and fill in values

# --- Server Settings (all tiers) ---
# AKGENTIC_HOST=0.0.0.0
# AKGENTIC_PORT=8000
# AKGENTIC_CORS_ORIGINS=["*"]
# AKGENTIC_FRONTEND_ADAPTER=

# --- Community Settings ---
# AKGENTIC_WORKSPACES_ROOT=workspaces
# AKGENTIC_EVENT_STORE_PATH=data/event_store
# AKGENTIC_CATALOG_PATH=data/catalog
# AKGENTIC_CHANNEL_REGISTRY_PATH=          # Path to channel registry YAML; disabled when unset

# --- LLM Provider Keys (at least one required for agents to function) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# MISTRAL_API_KEY=
# GOOGLE_API_KEY=
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=

# --- Tool Provider Keys (optional) ---
# TAVILY_API_KEY=                           # Required for Tavily web search tool

# --- Observability (optional) ---
# LOGFIRE_TOKEN=
# LOGFIRE_SEND_TO_LOGFIRE=                  # Controls whether telemetry is sent
